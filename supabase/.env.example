# Supabase Edge Functions Environment Variables
# Configure these in your Supabase project dashboard under Edge Functions > Secrets

# Supabase Configuration (auto-provided by Supabase)
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Wallet Encryption Key (CRITICAL - Keep this secret!)
# Generate a strong random key: openssl rand -base64 32
WALLET_ENCRYPTION_KEY=your_strong_encryption_key_here

# Blockchain Configuration
NETWORK=base  # Use 'base' for mainnet, 'baseSepolia' for testing
BASE_RPC_URL=https://mainnet.base.org
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Use Alchemy or Infura for better reliability (RECOMMENDED for production)
# BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_API_KEY

# Deposit Monitoring (for cron job)
# Set this to control how often deposits are checked
DEPOSIT_CHECK_INTERVAL=60  # seconds

