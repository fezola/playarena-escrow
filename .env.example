# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Blockchain Configuration
VITE_NETWORK=base  # Use 'base' for mainnet, 'baseSepolia' for testing
VITE_BASE_RPC_URL=https://mainnet.base.org
VITE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Optional: Use Alchemy or Infura for better reliability (recommended for production)
# VITE_BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# Contract Addresses (optional - defaults are provided)
VITE_ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_PLATFORM_FEE_BPS=250  # 250 = 2.5% fee

# Note: Server-side environment variables are configured in Supabase Edge Functions
# See supabase/.env.example for server configuration

